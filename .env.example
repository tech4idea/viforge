# Product profile. Allowed values: novel-adaptation, sitcom
VIWORK_PRODUCT=novel-adaptation

# Optional: leave empty for docker compose. Web proxies /api to the api service.
VITE_API_BASE_URL=

# Published host ports
VIWORK_API_PORT=13001
VIWORK_WEB_PORT=18080
VIWORK_POSTGRES_PORT=25432
VIWORK_QDRANT_PORT=16333

# Optional: host path mounted into the api container as /data.
# Set this to a directory outside the repo to avoid workspace/git interference.
VIWORK_API_DATA_DIR=./var/api-data

# PostgreSQL credentials used by the compose postgres service.
POSTGRES_DB=viwork
POSTGRES_USER=viwork
POSTGRES_PASSWORD=viwork

# AIGC Hub required by API runtime
VIWORK_AIGC_HUB_BASE_URL=
VIWORK_AIGC_HUB_API_KEY=
VIWORK_AIGC_HUB_APP_ID=viwork-novel-adaptation

# Optional AIGC Hub model overrides
VIWORK_AIGC_HUB_CHAT_MODEL=
VIWORK_AIGC_HUB_IMAGE_MODEL=
VIWORK_AIGC_HUB_EMBEDDING_MODEL=doubao-embedding-vision
VIWORK_LANGGRAPH_STORE_EMBEDDING_DIMS=1024

# LangGraph memory storage is wired internally by docker-compose.yml.
# Override DATABASE_URL/QDRANT_URL only when running the API outside compose.
