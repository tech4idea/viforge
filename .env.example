# Product profile. Allowed values: novel-adaptation, sitcom
VIWORK_PRODUCT=novel-adaptation

# Browser direct access to API, no reverse proxy.
VITE_API_BASE_URL=http://localhost:13001

# Published host ports
VIWORK_API_PORT=13001
VIWORK_WEB_PORT=18080

# AIGC Hub required by API runtime
VIWORK_AIGC_HUB_BASE_URL=
VIWORK_AIGC_HUB_API_KEY=
VIWORK_AIGC_HUB_APP_ID=viwork-novel-adaptation

# Optional AIGC Hub model overrides
VIWORK_AIGC_HUB_CHAT_MODEL=
VIWORK_AIGC_HUB_IMAGE_MODEL=
VIWORK_AIGC_HUB_EMBEDDING_MODEL=doubao-embedding-vision

# Mastra memory storage (PostgreSQL + Qdrant)
DATABASE_URL=postgresql://viwork:viwork@localhost:15432/viwork
QDRANT_URL=http://localhost:16333
