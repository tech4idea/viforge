# Product profile. Allowed values: novel-adaptation, sitcom
VIFORGE_PRODUCT=novel-adaptation

# Optional: leave empty for docker compose. Web proxies /api to the api service.
VITE_API_BASE_URL=

# Published host ports
VIFORGE_API_PORT=13001
VIFORGE_WEB_PORT=18080
VIFORGE_POSTGRES_PORT=25432
VIFORGE_QDRANT_PORT=16333

# Optional: host path mounted into the api container as /data.
# Set this to a directory outside the repo to avoid workspace/git interference.
VIFORGE_API_DATA_DIR=./var/api-data

# PostgreSQL credentials used by the compose postgres service.
POSTGRES_DB=viforge
POSTGRES_USER=viforge
POSTGRES_PASSWORD=viforge

# AIGC Hub required by API runtime
VIFORGE_AIGC_HUB_BASE_URL=
VIFORGE_AIGC_HUB_API_KEY=
VIFORGE_AIGC_HUB_APP_ID=viforge-novel-adaptation

# Optional AIGC Hub model overrides
VIFORGE_AIGC_HUB_CHAT_MODEL=
VIFORGE_WECHAT_CHAT_MODEL=minimax/minimax-m2.7
VIFORGE_AIGC_HUB_IMAGE_MODEL=
VIFORGE_AIGC_HUB_EMBEDDING_MODEL=doubao-embedding-vision
VIFORGE_LANGGRAPH_STORE_EMBEDDING_DIMS=1024

# Optional Playwriter browser relay used by agent browser tools.
# In Docker Compose this defaults to the Playwriter relay running on the WSL host.
# Start relay with: playwriter serve --host 0.0.0.0 --token <token> --replace
VIFORGE_PLAYWRITER_BIN=/app/apps/api/node_modules/.bin/playwriter
VIFORGE_PLAYWRITER_HOST=http://host.docker.internal:19988
VIFORGE_PLAYWRITER_TOKEN=
VIFORGE_PLAYWRITER_SESSION_ID=
VIFORGE_PLAYWRITER_HOST_HEADER=

# Phoenix traces/spans for LangGraph and LangChain runs.
PHOENIX_COLLECTOR_ENDPOINT=http://192.168.43.167:6006
PHOENIX_PROJECT_NAME=viforge
PHOENIX_SERVICE_NAME=viforge-api

# LangGraph memory storage is wired internally by docker-compose.yml.
# Override DATABASE_URL/QDRANT_URL only when running the API outside compose.
