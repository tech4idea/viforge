{
  "name": "viforge",
  "private": true,
  "license": "MIT",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "pnpm --parallel --filter @viforge/api --filter @viforge/web dev",
    "dev:api": "pnpm --filter @viforge/api dev",
    "dev:web": "pnpm --filter @viforge/web dev",
    "dev:desktop": "pnpm --filter @viforge/desktop dev",
    "dev:agent-worker": "pnpm --filter @viforge/agent-worker dev",
    "dev:integration-gateway": "pnpm --filter @viforge/integration-gateway dev",
    "desktop:pack": "pnpm --filter @viforge/desktop run pack",
    "desktop:dist": "pnpm --filter @viforge/desktop run dist",
    "licenses:list": "pnpm licenses list --long",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "typescript": "^5.5.3"
  }
}
